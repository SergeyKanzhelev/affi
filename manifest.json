{
  "manifest_version": 3,
  "name": "affi",
  "version": "1.0.0",
  "description": "Understand aliases in Kubernetes OWNERS files.",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*", "https://raw.githubusercontent.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/blob/*/OWNERS", "https://github.com/*/*/blob/*/OWNERS_ALIASES"],
      "js": ["js-yaml.min.js", "parser.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["maintainers_stats.json"],
      "matches": ["https://github.com/*"]
    }
  ]
}